## treeowen/src/Makevars
##
## Set C++ standard and OpenMP flags.
## Rcpp include path: R CMD INSTALL adds it automatically via LinkingTo: Rcpp
## in DESCRIPTION.  If you encounter 'Rcpp.h not found', ensure Rcpp is
## installed: install.packages("Rcpp")

CXX_STD     = CXX11
PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS)
PKG_LIBS     = $(SHLIB_OPENMP_CXXFLAGS)
