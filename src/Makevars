## treeowen/src/Makevars
##
## Rcpp include path is injected via Rscript so the package compiles
## on non-standard R installations (e.g. macOS arm64 /opt/R/arm64).

RCPP_CFLAGS = $(shell Rscript --no-save --no-restore \
    -e "cat(Rcpp:::CxxFlags())" 2>/dev/null)

CXX_STD      = CXX11
PKG_CXXFLAGS = $(RCPP_CFLAGS) $(SHLIB_OPENMP_CXXFLAGS)
PKG_LIBS     = $(SHLIB_OPENMP_CXXFLAGS)
