## treeowen/src/Makevars
##
## Rcpp include path resolution — multiple fallback strategies:
##
##  1. Rscript -e "cat(Rcpp:::CxxFlags())"      — preferred (works on all platforms)
##  2. R_INCLUDE_DIR/../../library/Rcpp/include  — standard R library path
##  3. R_HOME/library/Rcpp/include               — alternative standard path
##
## If all three fail the compiler will still find Rcpp.h through the
## -I path that R CMD INSTALL adds automatically for LinkingTo: Rcpp
## packages (present in all R >= 3.0).

## Strategy 1: ask Rcpp directly (most reliable)
RCPP_CFLAGS1 = $(shell Rscript --no-save --no-restore \
    -e "cat(Rcpp:::CxxFlags())" 2>/dev/null)

## Strategy 2: derive from R_HOME (R CMD INSTALL always sets R_HOME)
RCPP_CFLAGS2 = -I"$(R_HOME)/library/Rcpp/include"

## Use strategy 1 when non-empty, else strategy 2
RCPP_CFLAGS = $(if $(RCPP_CFLAGS1),$(RCPP_CFLAGS1),$(RCPP_CFLAGS2))

CXX_STD      = CXX11
PKG_CXXFLAGS = $(RCPP_CFLAGS) $(SHLIB_OPENMP_CXXFLAGS)
PKG_LIBS     = $(SHLIB_OPENMP_CXXFLAGS)
